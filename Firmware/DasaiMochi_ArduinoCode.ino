// STATE
int normalFrame = 0;
int happyFrame = 0;
bool wasTouched = false;

// SOUND
void playTone(int freq, int duration) {
  ledcWriteTone(BUZZER_CHANNEL, freq);
  delay(duration);
  ledcWriteTone(BUZZER_CHANNEL, 0);
}

void happySound() {
  playTone(988, 120);
  playTone(1318, 120);
  playTone(1760, 150);
}


void playAnimation(const unsigned char** frames, int frameCount, int &currentFrame) {
  currentFrame++;
  if (currentFrame >= frameCount) currentFrame = 0;

  u8g2.clearBuffer();
  u8g2.drawXBMP(0, 0, 128, 64, frames[currentFrame]);
  u8g2.sendBuffer();

  delay(40);
}


void setup(void) {
	pinMode(TOUCH_PIN, INPUT);

	Wire.begin(PIN_SDA, PIN_SCL);
  u8g2.begin();
	setupI2S();
}


void loop() {
  bool touched = digitalRead(TOUCH_PIN);

  if (touched && !wasTouched) {
    happySound();
    happyFrame = 0; 
  }

  if (touched) {
    playAnimation(happyFrames, HAPPY_FRAME_COUNT, happyFrame);
  } else {
    playAnimation(normalFrames, NORMAL_FRAME_COUNT, normalFrame);
  }

  wasTouched = touched;
}

